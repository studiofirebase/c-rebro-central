{
  "name": "marketplace-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max_old_space_size=16384 next build",
    "start": "next start -p $PORT -H 0.0.0.0",
    "lint": "NODE_OPTIONS=--max_old_space_size=4096 eslint \"src/app/**/*.{js,jsx,ts,tsx}\" --no-error-on-unmatched-pattern",
    "lint:debug": "NODE_OPTIONS=--max_old_space_size=4096 eslint \"src/app/**/*.{js,jsx,ts,tsx}\" --no-error-on-unmatched-pattern --debug",
    "typecheck:debug": "NODE_OPTIONS=--max_old_space_size=8192 tsc -p tsconfig.json --noEmit --pretty false --diagnostics --extendedDiagnostics",
    "check:all": "npm run typecheck:debug && npm run lint:debug",
    "check:sdk": "node scripts/check-sdk-config.js",
    "validate:env": "node scripts/validate-env.js",
    "test": "jest",
    "test:admin-isolation": "jest __tests__/admin-isolation.test.ts",
    "test:profile-isolation": "node scripts/test-admin-registration-profile.js",
    "test:uid-isolation": "bash scripts/test-uid-isolation.sh",
    "test:admin-middleware-isolation": "bash scripts/test-admin-middleware-isolation.sh",
    "test:isolation": "npm run test:profile-isolation && npm run test:uid-isolation && npm run test:admin-middleware-isolation",
    "test:youtube-access": "tsx scripts/test-youtube-access.ts",
    "test:passkey:local": "tsx scripts/test-passkey-flow.ts --env local --baseUrl http://localhost:3000",
    "test:passkey:prod": "tsx scripts/test-passkey-flow.ts --env prod",
    "genkit:init": "bash scripts/init-gemini.sh",
    "genkit:dev": "genkit start",
    "genkit:dev:with-env": "GENKIT_DEV=true npm run dev",
    "ai:brain": "node -e 'const { centralAssistantBrain } = require(\"./genkit-flow.js\"); centralAssistantBrain.run({ question: process.argv[1] || \"Olá\" }).then(r => console.log(r)).catch(err => console.error(err))'"
  },
