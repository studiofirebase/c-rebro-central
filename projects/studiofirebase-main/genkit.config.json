{
  "name": "centralAssistantBrain",
  "version": "1.0.0",
  "genkit": {
    "module": "./genkit-flow.ts",
    "plugins": [
      {
        "id": "@genkit-ai/googleai",
        "config": {
          "apiKey": "${GOOGLE_GENAI_API_KEY}"
        }
      }
    ]
  },
  "environment": {
    "GOOGLE_GENAI_API_KEY": "Sua chave de API do Google AI (obtenha em https://ai.google.dev)"
  }
}
