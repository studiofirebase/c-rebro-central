rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      // The superadmin is identified by the 'superadmin' role in the auth token.
      return request.auth != null && request.auth.token.role == 'superadmin';
    }

    function isAdmin() {
      return request.auth != null && (
        isSuperAdmin() || // A superadmin is always an admin
        request.auth.token.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null; // Allow creation, next-auth handles initial user data
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == userId && request.resource.data.role == resource.data.role); // User can update own profile, but not change own role
    }

    // Secret chat collection - allow public access for visitors
    match /chats/{chatId} {
      // Allow anyone to create a new secret chat
      allow create: if true;
      // Allow reading chat metadata
      allow read: if true;
      // Allow updates only for admins
      allow update, delete: if isAdmin();
      
      // Messages subcollection
      match /messages/{messageId} {
        // Allow anyone to read and write messages in the chat
        allow read, create: if true;
        // Only admins can delete messages
        allow update, delete: if isAdmin();
      }
    }

    function isCallParticipant(callId) {
      return request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
    }

    match /calls/{callId} {
      allow create: if request.auth != null &&
        request.resource.data.participants is list &&
        request.auth.uid in request.resource.data.participants;
      allow read, update, delete: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      match /offerCandidates/{candidateId} {
        allow read, create, delete: if isCallParticipant(callId);
      }

      match /answerCandidates/{candidateId} {
        allow read, create, delete: if isCallParticipant(callId);
      }
    }

    // Categories collection - public read for active items, admin write
    match /categories/{id} {
      allow read: if !('status' in resource.data) || resource.data.status == true || isAdmin();
      allow write: if isAdmin();
    }

    // Topics collection - public read for active items, admin write
    match /topics/{id} {
      allow read: if !('status' in resource.data) || resource.data.status == true || isAdmin();
      allow write: if isAdmin();
    }

    // Generic rule for all other collections.
    // SuperAdmin gets full access.
    // Regular admins get access to an allowlist of collections.
    match /{collectionId}/{docId} {
      allow read, write: if isSuperAdmin() || (isAdmin() && collectionId in [
        'admin_audit_log',
        'admin_log',
        'admin_twitter_accounts',
        'admin_twitter_photos',
        'admin_twtitter_videos',
        'admins',
        'all',
        'audit_logs',
        'cache',
        'content',
        'conversations',
        'exclusiveContent',
        'facebook_cache',
        'facebook_fotos',
        'facebook_videos',
        'feedbacks',
        'imageLabels',
        'instagram_cache',
        'instagram_photos',
        'instagram_videos',
        'logs',
        'mail',
        'mail_templates',
        'notifications',
        'pedidos',
        'pending_admin_registration',
        'products',
        'reviews',
        'settings',
        'sms_queue',
        'subscribers',
        'subscriptions',
        'twitter-cache',
        'twitter-photos',
        'twitter-videos',
        'usuarios',
        'verification_codes',
        'video',
        'videos',
        'webhooks'
      ]);
    }
  }
}
